---
const year = new Date().getFullYear();
---

<footer class="bg-gray-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <div>
        <div class="flex items-center gap-2.5 mb-4">
          <svg class="w-8 h-8" viewBox="0 0 36 36" fill="none">
            <circle cx="18" cy="18" r="16" fill="url(#genieGradF)" />
            <path d="M18 9C18 9 22.5 15.5 22.5 20C22.5 22.5 20.5 24.5 18 24.5C15.5 24.5 13.5 22.5 13.5 20C13.5 15.5 18 9 18 9Z" fill="white" opacity="0.9" />
            <defs>
              <linearGradient id="genieGradF" x1="0" y1="0" x2="36" y2="36">
                <stop stop-color="#7C3AED" />
                <stop offset="0.5" stop-color="#EC4899" />
                <stop offset="1" stop-color="#F97316" />
              </linearGradient>
            </defs>
          </svg>
          <span class="text-lg font-extrabold tracking-tight text-white">Hello <span class="text-purple-400">Genie</span></span>
        </div>
        <p class="text-sm text-gray-400 leading-relaxed">Your AI Business Assistant. Automation that feels like magic.</p>
      </div>

      <div>
        <h4 class="text-white font-semibold mb-4 text-sm">Features</h4>
        <ul class="space-y-3 text-sm text-gray-400">
          <li><a href="/features" class="hover:text-purple-400 transition-colors">Smart Scheduling</a></li>
          <li><a href="/features" class="hover:text-purple-400 transition-colors">Customer Comms</a></li>
          <li><a href="/features" class="hover:text-purple-400 transition-colors">Document Processing</a></li>
          <li><a href="/features" class="hover:text-purple-400 transition-colors">Workflow Automation</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-white font-semibold mb-4 text-sm">Company</h4>
        <ul class="space-y-3 text-sm text-gray-400">
          <li><a href="/about" class="hover:text-purple-400 transition-colors">About</a></li>
          <li><a href="/pricing" class="hover:text-purple-400 transition-colors">Pricing</a></li>
          <li><a href="/contact" class="hover:text-purple-400 transition-colors">Contact</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-white font-semibold mb-4 text-sm">Say Hello</h4>
        <p class="text-sm text-gray-400 mb-4">hello@hello-genie.com</p>
        <a href="/contact" class="inline-block px-5 py-2 rounded-full bg-purple-600/20 text-purple-400 text-sm font-medium hover:bg-purple-600/30 transition-colors">
          Join the Waitlist
        </a>
      </div>
    </div>

    <div class="border-t border-gray-800 mt-12 pt-8 text-sm text-gray-500 text-center">
      &copy; {year} Hello Genie. All rights reserved.
    </div>
  </div>
</footer>
