---
const year = new Date().getFullYear();
---

<footer class="bg-gray-900 text-gray-400 py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <div>
        <span class="text-xl font-bold text-white">Hello <span class="text-purple-400">Genie</span></span>
        <p class="mt-3 text-sm">Your AI Business Assistant — Automation Made Simple</p>
      </div>
      <div>
        <h4 class="text-white font-semibold mb-3">Features</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/features" class="hover:text-purple-400 transition-colors">Smart Scheduling</a></li>
          <li><a href="/features" class="hover:text-purple-400 transition-colors">Customer Comms</a></li>
          <li><a href="/features" class="hover:text-purple-400 transition-colors">Document Processing</a></li>
          <li><a href="/features" class="hover:text-purple-400 transition-colors">Workflow Automation</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-white font-semibold mb-3">Company</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/about" class="hover:text-purple-400 transition-colors">About</a></li>
          <li><a href="/pricing" class="hover:text-purple-400 transition-colors">Pricing</a></li>
          <li><a href="/contact" class="hover:text-purple-400 transition-colors">Contact</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-white font-semibold mb-3">Connect</h4>
        <p class="text-sm">hello@hello-genie.com</p>
      </div>
    </div>
    <div class="border-t border-gray-800 mt-8 pt-8 text-sm text-center">
      &copy; {year} Hello Genie. All rights reserved.
    </div>
  </div>
</footer>
