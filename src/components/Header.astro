---
const currentPath = Astro.url.pathname;
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/features', label: 'Features' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-lg border-b border-purple-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-2">
        <svg class="w-8 h-8" viewBox="0 0 32 32" fill="none">
          <circle cx="16" cy="16" r="14" fill="url(#genieGrad)" />
          <path d="M16 8C16 8 20 14 20 18C20 20.2 18.2 22 16 22C13.8 22 12 20.2 12 18C12 14 16 8 16 8Z" fill="white" opacity="0.9" />
          <defs>
            <linearGradient id="genieGrad" x1="0" y1="0" x2="32" y2="32">
              <stop stop-color="#7C3AED" />
              <stop offset="1" stop-color="#F97316" />
            </linearGradient>
          </defs>
        </svg>
        <span class="text-xl font-bold text-gray-900">Hello <span class="gradient-text">Genie</span></span>
      </a>
      <nav class="hidden md:flex items-center gap-8">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`text-sm font-medium transition-colors ${
              currentPath === link.href
                ? 'text-purple-600'
                : 'text-gray-600 hover:text-purple-600'
            }`}
          >
            {link.label}
          </a>
        ))}
      </nav>
      <a href="/contact" class="hidden md:inline-block btn-primary text-sm !py-2 !px-4">
        Join the Waitlist
      </a>
    </div>
  </div>
</header>
