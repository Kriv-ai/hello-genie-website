---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Pricing" description="Hello Genie pricing — simple, honest plans for small businesses. Early members get founding pricing locked in for life.">
  <Header />
  <main class="pt-16">

    <!-- ════ HERO ════ -->
    <section class="hero-bg section-padding wave-divider relative" style="padding-top: 7rem; padding-bottom: 6rem;">
      <div class="max-w-4xl mx-auto text-center relative z-10">
        <div class="badge-pill bg-pink-100 text-pink-700 mx-auto w-fit mb-6 animate-fade-in">Pricing</div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-gray-900 leading-[1.1] tracking-tight animate-fade-in animate-delay-1">
          Simple, Honest<br /><span class="gradient-text">Pricing</span>
        </h1>
        <p class="mt-6 text-lg text-gray-600 max-w-2xl mx-auto leading-relaxed animate-fade-in animate-delay-2">
          No hidden fees, no surprises. Pick a plan that fits your business. Join the waitlist now and lock in founding member pricing — forever.
        </p>
      </div>
    </section>

    <!-- ════ PRICING TIERS ════ -->
    <section class="section-light section-padding">
      <div class="max-w-5xl mx-auto reveal">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

          <!-- Starter -->
          <div class="pricing-card p-8">
            <h3 class="text-lg font-bold text-gray-900">Starter</h3>
            <p class="text-sm text-gray-500 mt-1">For solo entrepreneurs</p>
            <div class="mt-6">
              <div class="text-5xl font-black text-gray-900">$29</div>
              <p class="text-sm text-gray-400 mt-1">/month</p>
            </div>
            <div class="mt-8 space-y-4">
              <div class="flex items-start gap-3">
                <svg class="check-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                <span class="text-sm text-gray-600">1 user</span>
              </div>
              <div class="flex items-start gap-3">
                <svg class="check-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                <span class="text-sm text-gray-600">Smart scheduling</span>
              </div>
              <div class="flex items-start gap-3">
                <svg class="check-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                <span class="text-sm text-gray-600">Email automation (50/day)</span>
              </div>
              <div class="flex items-start gap-3">
                <svg class="check-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                <span class="text-sm text-gray-600">Basic document processing</span>
              </div>
              <div class="flex items-start gap-3">
                <svg class="check-icon opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                <span class="text-sm text-gray-400">5 workflow automations</span>
              </div>
            </div>
            <div class="mt-8">
              <a href="/contact" class="block text-center px-6 py-3 rounded-full border-2 border-purple-200 text-purple-600 font-semibold hover:bg-purple-50 transition-colors">Join Waitlist</a>
            </div>
          </div>

          <!-- Growth -->
          <div class="pricing-card featured p-8 relative">
            <div class="absolute -top-3 left-1/2 -translate-x-1/2">
              <span class="badge-pill bg-purple-600 text-white text-xs">Most Popular</span>
            </div>
            <h3 class="text-lg font-bold text-gray-900">Growth</h3>
            <p class="text-sm text-gray-500 mt-1">For growing teams</p>
            <div class="mt-6">
              <div class="text-5xl font-black gradient-text">$79</div>
              <p class="text-sm text-gray-400 mt-1">/month</p>
            </div>
            <div class="mt-8 space-y-4">
              <div class="flex items-start gap-3">
                <svg class="check-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                <span class="text-sm text-gray-600">Up to 5 users</span>
              </div>
              <div class="flex items-start gap-3">
                <svg class="check-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                <span class="text-sm text-gray-600">Full automation suite</span>
              </div>
              <div class="flex items-start gap-3">
                <svg class="check-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                <span class="text-sm text-gray-600">Unlimited email automation</span>
              </div>
              <div class="flex items-start gap-3">
                <svg class="check-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                <span class="text-sm text-gray-600">Advanced document processing</span>
              </div>
              <div class="flex items-start gap-3">
                <svg class="check-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                <span class="text-sm text-gray-600">Unlimited workflows</span>
              </div>
              <div class="flex items-start gap-3">
                <svg class="check-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                <span class="text-sm text-gray-600">Priority support</span>
              </div>
            </div>
            <div class="mt-8">
              <a href="/contact" class="btn-primary block text-center">Join Waitlist</a>
            </div>
          </div>

          <!-- Pro -->
          <div class="pricing-card p-8">
            <h3 class="text-lg font-bold text-gray-900">Pro</h3>
            <p class="text-sm text-gray-500 mt-1">For established businesses</p>
            <div class="mt-6">
              <div class="text-5xl font-black text-gray-900">$199</div>
              <p class="text-sm text-gray-400 mt-1">/month</p>
            </div>
            <div class="mt-8 space-y-4">
              <div class="flex items-start gap-3">
                <svg class="check-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                <span class="text-sm text-gray-600">Unlimited users</span>
              </div>
              <div class="flex items-start gap-3">
                <svg class="check-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                <span class="text-sm text-gray-600">Everything in Growth</span>
              </div>
              <div class="flex items-start gap-3">
                <svg class="check-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                <span class="text-sm text-gray-600">Custom AI model training</span>
              </div>
              <div class="flex items-start gap-3">
                <svg class="check-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                <span class="text-sm text-gray-600">API access</span>
              </div>
              <div class="flex items-start gap-3">
                <svg class="check-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                <span class="text-sm text-gray-600">Dedicated account manager</span>
              </div>
            </div>
            <div class="mt-8">
              <a href="/contact" class="block text-center px-6 py-3 rounded-full border-2 border-purple-200 text-purple-600 font-semibold hover:bg-purple-50 transition-colors">Join Waitlist</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ════ FOUNDING MEMBER PERKS ════ -->
    <section class="section-warm section-padding">
      <div class="max-w-4xl mx-auto reveal">
        <div class="feature-card p-10 text-center">
          <div class="text-4xl mb-4">🎁</div>
          <h2 class="text-2xl md:text-3xl font-extrabold text-gray-900">Founding Member Benefits</h2>
          <p class="mt-4 text-gray-600 max-w-2xl mx-auto">Join the waitlist now and get exclusive perks when we launch.</p>
          <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-6 text-left">
            <div class="text-center">
              <div class="text-2xl mb-2">💰</div>
              <h3 class="font-bold text-gray-900 text-sm">Price Lock</h3>
              <p class="text-xs text-gray-500 mt-1">Your founding price never goes up — guaranteed for life</p>
            </div>
            <div class="text-center">
              <div class="text-2xl mb-2">🚀</div>
              <h3 class="font-bold text-gray-900 text-sm">Early Access</h3>
              <p class="text-xs text-gray-500 mt-1">Be the first to use new features before anyone else</p>
            </div>
            <div class="text-center">
              <div class="text-2xl mb-2">🎯</div>
              <h3 class="font-bold text-gray-900 text-sm">Direct Input</h3>
              <p class="text-xs text-gray-500 mt-1">Shape the product roadmap with your feedback</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ════ FAQ ════ -->
    <section class="section-light section-padding">
      <div class="max-w-3xl mx-auto reveal">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-extrabold text-gray-900">Common Questions</h2>
        </div>

        <div class="space-y-4">
          <div class="feature-card p-6">
            <h3 class="font-bold text-gray-900">When will Hello Genie launch?</h3>
            <p class="mt-2 text-sm text-gray-600">We're targeting a public launch in Q3 2026. Waitlist members get early access before the general public.</p>
          </div>
          <div class="feature-card p-6">
            <h3 class="font-bold text-gray-900">Is my data secure?</h3>
            <p class="mt-2 text-sm text-gray-600">Absolutely. We use end-to-end encryption, never sell your data, and never train our models on your business data. Your information stays yours.</p>
          </div>
          <div class="feature-card p-6">
            <h3 class="font-bold text-gray-900">Do I need technical skills?</h3>
            <p class="mt-2 text-sm text-gray-600">Not at all. Hello Genie is designed for non-technical business owners. If you can write an email, you can use Hello Genie.</p>
          </div>
          <div class="feature-card p-6">
            <h3 class="font-bold text-gray-900">What tools does it integrate with?</h3>
            <p class="mt-2 text-sm text-gray-600">Google Workspace, Microsoft 365, popular CRMs (HubSpot, Salesforce), accounting tools (QuickBooks, Xero), and 50+ more through our integration platform.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ════ CTA ════ -->
    <section class="section-purple section-padding">
      <div class="max-w-4xl mx-auto text-center reveal">
        <h2 class="text-3xl md:text-5xl font-extrabold text-white leading-tight">
          Don't Miss<br />Founding Pricing
        </h2>
        <p class="mt-6 text-purple-200 text-lg max-w-xl mx-auto">Lock in the lowest price we'll ever offer. Join the waitlist today.</p>
        <div class="mt-10">
          <a href="/contact" class="btn-white text-base">Join the Waitlist</a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
