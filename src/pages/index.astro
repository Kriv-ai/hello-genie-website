---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Your AI Business Assistant">
  <Header />
  <main class="pt-16">
    <!-- Hero -->
    <section class="gradient-bg section-padding">
      <div class="max-w-7xl mx-auto text-center">
        <h1 class="text-4xl md:text-6xl font-extrabold text-gray-900 leading-tight animate-fade-in">
          Your AI Business<br />
          <span class="gradient-text">Assistant</span>
        </h1>
        <p class="mt-6 text-lg md:text-xl text-gray-600 max-w-3xl mx-auto animate-fade-in animate-delay-1">
          Stop drowning in admin work. Hello Genie automates scheduling, customer communication, document processing, and workflows — so you can focus on growing your business.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center animate-fade-in animate-delay-2">
          <a href="/contact" class="btn-primary">Join the Waitlist</a>
          <a href="/features" class="px-6 py-3 border border-purple-200 rounded-full text-purple-700 font-semibold hover:bg-purple-50 transition-colors">
            See Features
          </a>
        </div>
      </div>
    </section>

    <!-- Problem -->
    <section class="bg-white section-padding">
      <div class="max-w-7xl mx-auto text-center">
        <h2 class="text-3xl font-bold text-gray-900">Small Businesses Spend <span class="gradient-text">40%</span> of Their Time on Admin</h2>
        <p class="mt-4 text-gray-600 max-w-2xl mx-auto">Scheduling, emails, invoices, data entry — it never ends. Hello Genie handles the repetitive work so you don't have to.</p>
      </div>
    </section>

    <!-- Features -->
    <section class="bg-gray-50 section-padding">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-gray-900">Everything You Need</h2>
        <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="glass-card rounded-2xl p-6">
            <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
            </div>
            <h3 class="font-semibold text-gray-900">Smart Scheduling</h3>
            <p class="mt-2 text-sm text-gray-600">AI that manages your calendar, finds optimal meeting times, and handles rescheduling automatically.</p>
          </div>
          <div class="glass-card rounded-2xl p-6">
            <div class="w-12 h-12 bg-orange-100 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-orange-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
            </div>
            <h3 class="font-semibold text-gray-900">Customer Comms</h3>
            <p class="mt-2 text-sm text-gray-600">Automated email responses, chat support, and follow-ups that sound like you wrote them.</p>
          </div>
          <div class="glass-card rounded-2xl p-6">
            <div class="w-12 h-12 bg-pink-100 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-pink-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
            </div>
            <h3 class="font-semibold text-gray-900">Document Processing</h3>
            <p class="mt-2 text-sm text-gray-600">Extract data from invoices, contracts, and forms. Auto-file and organize everything.</p>
          </div>
          <div class="glass-card rounded-2xl p-6">
            <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
            </div>
            <h3 class="font-semibold text-gray-900">Workflow Automation</h3>
            <p class="mt-2 text-sm text-gray-600">Connect your tools and automate multi-step workflows. No coding required.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-white section-padding">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl font-bold text-gray-900">Be the First to Try Hello Genie</h2>
        <p class="mt-4 text-gray-600">We're building the AI assistant every small business deserves. Join the waitlist for early access.</p>
        <a href="/contact" class="btn-primary mt-8">Join the Waitlist</a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
